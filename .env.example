# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"

# RAPIDAPI_KEY: Optional custom key for the Job search integrations.
# If left blank, the applet will fall back to the built-in RapidAPI key.
RAPIDAPI_KEY=

# SUPABASE_URL: Supabase project URL for database access.
# When deployed on Vercel with the Vercel Supabase integration,
# this is automatically set as career_copilot_SUPABASE_URL.
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_KEY: Supabase anon/service key for database access.
# When deployed on Vercel with the Vercel Supabase integration,
# this is automatically set as career_copilot_SUPABASE_SECRET_KEY.
SUPABASE_KEY="your-supabase-key"

# RESEND_API_KEY: Resend API key for sending verification emails.
RESEND_API_KEY="your-resend-api-key"

# SMTP_HOST: Optional SMTP host for sending emails via Nodemailer.
# If set, emails will be sent via SMTP instead of Resend.
# Examples: smtp.gmail.com, smtp.office365.com, smtp.mailgun.org
SMTP_HOST=

# SMTP_PORT: SMTP port (default: 587 for TLS, 465 for SSL).
SMTP_PORT=587

# SMTP_SECURE: Set to "true" to use SSL/TLS from the start (port 465).
SMTP_SECURE=false

# SMTP_USER: SMTP authentication username/email.
SMTP_USER=

# SMTP_PASS: SMTP authentication password or app password.
SMTP_PASS=

# EMAIL_FROM: Default sender address for application emails.
EMAIL_FROM="Aura Career <onboarding@resend.dev>"

# PORT: Server port (default: 3000). Ignored on Vercel.
PORT=3000

# NODE_ENV: Environment mode. Set to "production" for production builds.
NODE_ENV=development

# VITE_APP_URL: The public-facing production URL of the frontend (for SEO canonical/OG replacement).
VITE_APP_URL="https://your-production-app.vercel.app/"

# ADMIN_EMAIL & ADMIN_PASSWORD: Credentials used to seed the initial system administrator.
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="super-secure-admin-password"

