# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"

# RAPIDAPI_KEY: Optional custom key for the Job search integrations.
# If left blank, the applet will fall back to the built-in RapidAPI key.
RAPIDAPI_KEY=

# SUPABASE_URL: Supabase project URL for database access.
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_KEY: Supabase anon/service key for database access.
SUPABASE_KEY="your-supabase-key"

# RESEND_API_KEY: Resend API key for sending verification emails.
RESEND_API_KEY="your-resend-api-key"

# PORT: Server port (default: 3000). Ignored on Vercel.
PORT=3000

# NODE_ENV: Environment mode. Set to "production" for production builds.
NODE_ENV=development
